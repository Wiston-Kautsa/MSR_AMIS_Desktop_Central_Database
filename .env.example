# Desktop application mode.
# Production clients should use REMOTE_API so work does not silently fall back to SQLite.
# Use AUTO only in development or after sync conflict rules have been fully tested.
MSR_AMIS_DATA_MODE=REMOTE_API
MSR_AMIS_API_BASE_URL=http://143.198.153.43:8090
# Leave false on slower networks. Full local mirror refresh still happens
# after login; mutation screens should not pull every server table after each save.
MSR_AMIS_AUTO_MIRROR_AFTER_MUTATION=false

# Development aliases also supported by the desktop loader.
APP_MODE=REMOTE_API
API_BASE_URL=http://143.198.153.43:8090

# API / PostgreSQL settings.
# Real OS/server environment variables override this file.
MSR_AMIS_API_PORT=8090
MSR_AMIS_DB_URL=jdbc:postgresql://localhost:5432/msr_amis
MSR_AMIS_DB_USERNAME=postgres
MSR_AMIS_DB_PASSWORD=postgres
MSR_AMIS_JWT_SECRET=VGhpc0lzQVN0cm9uZ0RldmVsb3BtZW50U2VjcmV0S2V5Rm9yTVNSQU1JUw==
MSR_AMIS_JWT_EXPIRATION_SECONDS=28800
MSR_AMIS_PRIMARY_SUPER_ADMIN_EMAIL=msramis@nlgfc.gov.mw
MSR_AMIS_SETUP_ADMIN_EMAIL=setup-admin@example.com
MSR_AMIS_SETUP_USER_EMAIL=setup-user@example.com

# Comma-separated reserved emails by role. Leave a list empty to remove role-specific reservations.
MSR_AMIS_RESERVED_SUPER_ADMIN_EMAILS=msramis@nlgfc.gov.mw
MSR_AMIS_RESERVED_ADMIN_EMAILS=setup-admin@example.com
MSR_AMIS_RESERVED_USER_EMAILS=setup-user@example.com

# Password reset support.
# Keep false in production. Use true only for controlled development when SMTP is unavailable.
MSR_AMIS_EXPOSE_RESET_CODE_ON_EMAIL_FAILURE=false

# Password reset email sender.
MSR_AMIS_SMTP_HOST=mail.nlgfc.gov.mw
MSR_AMIS_SMTP_PORT=465
MSR_AMIS_SMTP_USERNAME=msramis@nlgfc.gov.mw
MSR_AMIS_SMTP_PASSWORD=replace_with_mailbox_password
MSR_AMIS_SMTP_FROM=msramis@nlgfc.gov.mw
MSR_AMIS_SMTP_STARTTLS=false
MSR_AMIS_SMTP_SSL=true
MSR_AMIS_SMTP_TIMEOUT_MS=10000

# Sends audit/status event emails only to MSR_AMIS_PRIMARY_SUPER_ADMIN_EMAIL.
MSR_AMIS_SUPER_USER_STATUS_EMAILS_ENABLED=true

# Sends distribution and return notifications to fixed recipients.
MSR_AMIS_OPERATION_EMAILS_ENABLED=false
MSR_AMIS_OPERATION_EMAIL_RECIPIENTS=msramis@nlgfc.gov.mw

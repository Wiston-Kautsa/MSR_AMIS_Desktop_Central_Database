<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="540.0" prefWidth="940.0"
            styleClass="login-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.LoginController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>
        <StackPane AnchorPane.topAnchor="0.0"
                   AnchorPane.rightAnchor="0.0"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0">
            <children>
                <HBox
                      styleClass="login-shell">
                    <children>
                        <VBox prefWidth="430.0"
                              spacing="16.0"
                              alignment="CENTER_LEFT"
                              HBox.hgrow="ALWAYS"
                              styleClass="login-brand-panel">
                            <padding>
                                <Insets top="42.0" right="42.0" bottom="42.0" left="42.0"/>
                            </padding>
                            <children>
                                <Label text="MSR AMIS" styleClass="login-brand-title"/>
                                <Label text="Malawi Social Registry" styleClass="login-brand-subtitle"/>
                                <Label text="Asset Management Information System"
                                       wrapText="true"
                                       styleClass="login-brand-subtitle"/>
                                <Label text="Track assets, assignments, returns, and reporting in one secure desktop system."
                                       wrapText="true"
                                       styleClass="login-brand-description"/>
                                <Label text="Secure asset tracking and management"
                                       wrapText="true"
                                       styleClass="login-brand-footnote"/>
                            </children>
                        </VBox>

                        <VBox prefWidth="470.0"
                              spacing="18.0"
                              alignment="CENTER_LEFT"
                              HBox.hgrow="ALWAYS"
                              styleClass="login-card-panel">
                            <padding>
                                <Insets top="42.0" right="52.0" bottom="42.0" left="52.0"/>
                            </padding>
                            <children>
                                <StackPane maxWidth="1.7976931348623157E308">
                                    <children>
                                        <VBox fx:id="loginPanel"
                                              spacing="18.0"
                                              alignment="CENTER_LEFT">
                                            <children>
                                                <VBox spacing="8.0">
                                                    <children>
                                                        <Label text="Welcome Back" styleClass="login-title"/>
                                                        <Label text="Sign in to continue to the system" styleClass="login-subtitle"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="8.0">
                                                    <children>
                                                        <Label text="Email" styleClass="login-input-label"/>
                                                        <ComboBox fx:id="cmbEmail"
                                                                  editable="true"
                                                                  promptText="Enter or select your email"
                                                                  prefHeight="44.0"
                                                                  maxWidth="1.7976931348623157E308"
                                                                  styleClass="login-input"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="8.0">
                                                    <children>
                                                        <Label text="Password" styleClass="login-input-label"/>
                                                        <StackPane>
                                                            <children>
                                                                <PasswordField fx:id="txtPassword"
                                                                               promptText="Enter your password"
                                                                               onAction="#handleLogin"
                                                                               prefHeight="44.0"
                                                                               maxWidth="1.7976931348623157E308"
                                                                               styleClass="login-input"/>
                                                                <TextField fx:id="txtPasswordVisible"
                                                                           promptText="Enter your password"
                                                                           onAction="#handleLogin"
                                                                           prefHeight="44.0"
                                                                           maxWidth="1.7976931348623157E308"
                                                                           managed="false"
                                                                           visible="false"
                                                                           styleClass="login-input"/>
                                                            </children>
                                                        </StackPane>
                                                    </children>
                                                </VBox>

                                                <HBox spacing="14.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <CheckBox fx:id="chkShowPassword"
                                                                  text="Show password"
                                                                  styleClass="login-checkbox"/>
                                                        <CheckBox fx:id="chkRememberLogin"
                                                                  text="Save credentials"
                                                                  styleClass="login-checkbox"/>
                                                    </children>
                                                </HBox>

                                                <Button fx:id="btnLogin"
                                                        text="LOGIN"
                                                        prefHeight="46.0"
                                                        maxWidth="1.7976931348623157E308"
                                                        defaultButton="true"
                                                        onAction="#handleLogin"
                                                        styleClass="login-primary-button"/>

                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Button text="Clear"
                                                                prefHeight="40.0"
                                                                maxWidth="1.7976931348623157E308"
                                                                HBox.hgrow="ALWAYS"
                                                                onAction="#handleClear"
                                                                styleClass="login-secondary-button"/>
                                                        <Button text="Reset Password"
                                                                prefHeight="40.0"
                                                                maxWidth="1.7976931348623157E308"
                                                        HBox.hgrow="ALWAYS"
                                                        onAction="#showResetPanel"
                                                        styleClass="login-secondary-button"/>
                                                    </children>
                                                </HBox>

                                                <Label fx:id="lblLoginStatus"
                                                       wrapText="true"
                                                       styleClass="login-message"/>
                                                <Label fx:id="lblDefaultAdmin"
                                                       wrapText="true"
                                                       styleClass="login-helper"/>
                                            </children>
                                        </VBox>

                                        <VBox fx:id="resetPanel"
                                              spacing="12.0"
                                              alignment="CENTER_LEFT"
                                              maxWidth="1.7976931348623157E308"
                                              managed="false"
                                              visible="false"
                                              styleClass="embedded-reset-panel">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                                    <children>
                                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label text="Reset your password" styleClass="login-title"/>
                                                                <Label text="Recover access inside the system without leaving the sign-in screen." styleClass="login-subtitle" wrapText="true"/>
                                                            </children>
                                                        </VBox>
                                                        <Button text="Back to Login"
                                                                onAction="#showLoginPanel"
                                                                styleClass="login-tertiary-button"/>
                                                    </children>
                                                </HBox>

                                                <TitledPane text="Account Recovery"
                                                            expanded="true"
                                                            animated="false"
                                                            collapsible="true"
                                                            maxWidth="1.7976931348623157E308"
                                                            styleClass="section-pane reset-titled-pane">
                                                    <content>
                                                        <VBox spacing="10.0"
                                                              fillWidth="true"
                                                              maxWidth="1.7976931348623157E308"
                                                              styleClass="reset-card">
                                                            <children>
                                                                <Label text="Verify the account before a reset code can be issued."
                                                                       wrapText="true"
                                                                       maxWidth="1.7976931348623157E308"
                                                                       styleClass="reset-step-text"/>
                                                                <VBox spacing="8.0" maxWidth="1.7976931348623157E308">
                                                                    <children>
                                                                        <Label text="Email or Username" styleClass="login-input-label"/>
                                                                        <TextField fx:id="txtResetIdentifier"
                                                                                   promptText="Enter your registered email or username"
                                                                                   onAction="#handleSendResetCode"
                                                                                   prefHeight="44.0"
                                                                                   maxWidth="1.7976931348623157E308"
                                                                                   styleClass="login-input"/>
                                                                    </children>
                                                                </VBox>
                                                                <HBox fx:id="resetStatusBanner"
                                                                      spacing="10.0"
                                                                      alignment="CENTER_LEFT"
                                                                      maxWidth="1.7976931348623157E308"
                                                                      styleClass="reset-status-banner">
                                                                    <children>
                                                                        <Label text="SYSTEM" styleClass="reset-status-chip"/>
                                                                        <Label fx:id="lblResetStatus"
                                                                               text="Ready to send a reset code."
                                                                               wrapText="true"
                                                                               maxWidth="1.7976931348623157E308"
                                                                               HBox.hgrow="ALWAYS"
                                                                               styleClass="reset-status-text"/>
                                                                    </children>
                                                                </HBox>
                                                                <Button fx:id="btnSendResetCode"
                                                                        text="Send Reset Code"
                                                                        prefHeight="42.0"
                                                                        maxWidth="1.7976931348623157E308"
                                                                        defaultButton="true"
                                                                        onAction="#handleSendResetCode"
                                                                        styleClass="login-primary-button"/>
                                                            </children>
                                                        </VBox>
                                                    </content>
                                                </TitledPane>

                                                <TitledPane text="Create New Password"
                                                            expanded="true"
                                                            animated="false"
                                                            collapsible="true"
                                                            maxWidth="1.7976931348623157E308"
                                                            styleClass="section-pane reset-titled-pane">
                                                    <content>
                                                        <VBox spacing="10.0"
                                                              fillWidth="true"
                                                              maxWidth="1.7976931348623157E308"
                                                              styleClass="reset-card">
                                                            <children>
                                                                <Label text="Enter the code from your inbox, then set and confirm the new password."
                                                                       wrapText="true"
                                                                       maxWidth="1.7976931348623157E308"
                                                                       styleClass="reset-step-text"/>
                                                                <VBox spacing="8.0" maxWidth="1.7976931348623157E308">
                                                                    <children>
                                                                        <Label text="Reset Code" styleClass="login-input-label"/>
                                                                        <TextField fx:id="txtResetCode"
                                                                                   promptText="Enter 6-digit reset code"
                                                                                   onAction="#handleSubmitPasswordReset"
                                                                                   prefHeight="44.0"
                                                                                   maxWidth="1.7976931348623157E308"
                                                                                   disable="true"
                                                                                   styleClass="login-input"/>
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="8.0" maxWidth="1.7976931348623157E308">
                                                                    <children>
                                                                        <Label text="New Password" styleClass="login-input-label"/>
                                                                        <PasswordField fx:id="txtResetNewPassword"
                                                                                       promptText="Enter new password"
                                                                                       onAction="#handleSubmitPasswordReset"
                                                                                       prefHeight="44.0"
                                                                                       maxWidth="1.7976931348623157E308"
                                                                                       disable="true"
                                                                                       styleClass="login-input"/>
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="8.0" maxWidth="1.7976931348623157E308">
                                                                    <children>
                                                                        <Label text="Confirm Password" styleClass="login-input-label"/>
                                                                        <PasswordField fx:id="txtResetConfirmPassword"
                                                                                       promptText="Confirm new password"
                                                                                       onAction="#handleSubmitPasswordReset"
                                                                                       prefHeight="44.0"
                                                                                       maxWidth="1.7976931348623157E308"
                                                                                       disable="true"
                                                                                       styleClass="login-input"/>
                                                                    </children>
                                                                </VBox>
                                                                <HBox spacing="10.0" maxWidth="1.7976931348623157E308">
                                                                    <children>
                                                                        <Button fx:id="btnResetPassword"
                                                                                text="Reset Password"
                                                                                prefHeight="42.0"
                                                                                maxWidth="1.7976931348623157E308"
                                                                                HBox.hgrow="ALWAYS"
                                                                                disable="true"
                                                                                defaultButton="true"
                                                                                onAction="#handleSubmitPasswordReset"
                                                                                styleClass="login-primary-button"/>
                                                                        <Button text="Clear Fields"
                                                                                prefHeight="42.0"
                                                                                maxWidth="1.7976931348623157E308"
                                                                                HBox.hgrow="ALWAYS"
                                                                                onAction="#clearResetFields"
                                                                                styleClass="login-secondary-button"/>
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                    </content>
                                                </TitledPane>
                                            </children>
                                        </VBox>

                                        <VBox fx:id="initialPasswordPanel"
                                              spacing="14.0"
                                              alignment="CENTER_LEFT"
                                              maxWidth="1.7976931348623157E308"
                                              managed="false"
                                              visible="false"
                                              styleClass="embedded-reset-panel">
                                            <children>
                                                <VBox spacing="6.0">
                                                    <children>
                                                        <Label text="Change Password" styleClass="login-title"/>
                                                        <Label text="Your account requires a new password before opening the dashboard."
                                                               wrapText="true"
                                                               styleClass="login-subtitle"/>
                                                    </children>
                                                </VBox>
                                                <HBox fx:id="initialPasswordStatusBanner"
                                                      spacing="10.0"
                                                      alignment="CENTER_LEFT"
                                                      maxWidth="1.7976931348623157E308"
                                                      styleClass="reset-status-banner">
                                                    <children>
                                                        <Label text="SECURITY" styleClass="reset-status-chip"/>
                                                        <Label fx:id="lblInitialPasswordStatus"
                                                               text="Create a strong password to continue."
                                                               wrapText="true"
                                                               maxWidth="1.7976931348623157E308"
                                                               HBox.hgrow="ALWAYS"
                                                               styleClass="reset-status-text"/>
                                                    </children>
                                                </HBox>
                                                <VBox spacing="8.0" maxWidth="1.7976931348623157E308">
                                                    <children>
                                                        <Label text="New Password" styleClass="login-input-label"/>
                                                        <PasswordField fx:id="txtInitialNewPassword"
                                                                       promptText="Enter new password"
                                                                       onAction="#handleInitialPasswordChange"
                                                                       prefHeight="44.0"
                                                                       maxWidth="1.7976931348623157E308"
                                                                       styleClass="login-input"/>
                                                    </children>
                                                </VBox>
                                                <VBox spacing="8.0" maxWidth="1.7976931348623157E308">
                                                    <children>
                                                        <Label text="Confirm Password" styleClass="login-input-label"/>
                                                        <PasswordField fx:id="txtInitialConfirmPassword"
                                                                       promptText="Confirm new password"
                                                                       onAction="#handleInitialPasswordChange"
                                                                       prefHeight="44.0"
                                                                       maxWidth="1.7976931348623157E308"
                                                                       styleClass="login-input"/>
                                                    </children>
                                                </VBox>
                                                <HBox spacing="10.0" maxWidth="1.7976931348623157E308">
                                                    <children>
                                                        <Button fx:id="btnInitialPasswordChange"
                                                                text="Change Password"
                                                                prefHeight="42.0"
                                                                maxWidth="1.7976931348623157E308"
                                                                HBox.hgrow="ALWAYS"
                                                                defaultButton="true"
                                                                onAction="#handleInitialPasswordChange"
                                                                styleClass="login-primary-button"/>
                                                        <Button text="Sign Out"
                                                                prefHeight="42.0"
                                                                maxWidth="1.7976931348623157E308"
                                                                HBox.hgrow="ALWAYS"
                                                                onAction="#handleInitialPasswordSignOut"
                                                                styleClass="login-secondary-button"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                    </children>
                                </StackPane>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </StackPane>
    </children>

</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/11"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.CreateAssignmentController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>

        <ScrollPane fitToWidth="true"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <content>

                <VBox spacing="20.0" styleClass="main-container">

                    <padding>
                        <Insets top="20.0" left="20.0" right="20.0" bottom="20.0"/>
                    </padding>

                    <Label text="Create Assignment"
                           styleClass="title-label"/>

                    <TitledPane text="Assignment Details" expanded="true" styleClass="card">

                        <content>

                            <GridPane hgap="15.0" vgap="15.0">

                                <padding>
                                    <Insets top="10.0" left="10.0" right="10.0" bottom="10.0"/>
                                </padding>

                                <columnConstraints>
                                    <ColumnConstraints percentWidth="30.0"/>
                                    <ColumnConstraints percentWidth="70.0"/>
                                </columnConstraints>

                                <Label text="Responsible Person:" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="cmbPerson"
                                          prefWidth="250"
                                          promptText="Select Responsible Person"
                                          GridPane.rowIndex="0"
                                          GridPane.columnIndex="1"/>

                                <Label text="Department:" GridPane.rowIndex="1"/>
                                <TextField fx:id="txtDepartment"
                                           promptText="Department"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="1"/>

                                <Label text="Equipment Category:" GridPane.rowIndex="2"/>
                                <VBox spacing="6.0"
                                      GridPane.rowIndex="2"
                                      GridPane.columnIndex="1">
                                    <children>
                                        <ComboBox fx:id="cmbEquipmentType"
                                                  prefWidth="250"
                                                  promptText="Select Existing Category"/>
                                        <Label fx:id="lblAvailableStock"
                                               text="Available in stock: Select existing category"
                                               styleClass="card-title"/>
                                    </children>
                                </VBox>

                                <Label text="Reason:" GridPane.rowIndex="3"/>
                                <TextField fx:id="txtReason"
                                           promptText="Reason for assignment"
                                           GridPane.rowIndex="3"
                                           GridPane.columnIndex="1"/>

                                <Label text="Quantity:" GridPane.rowIndex="4"/>
                                <TextField fx:id="txtQuantity"
                                           GridPane.rowIndex="4"
                                           GridPane.columnIndex="1"/>

                            </GridPane>

                        </content>

                    </TitledPane>

                    <HBox spacing="15.0" alignment="CENTER_RIGHT">

                        <Button text="Save Assignment"
                                onAction="#saveAssignment"
                                styleClass="btn-success"/>

                        <Button text="Clear"
                                onAction="#clearForm"
                                styleClass="btn-secondary"/>

                    </HBox>

                    <TitledPane text="Assignment Records" expanded="true" styleClass="card">

                        <content>

                            <VBox spacing="10.0">
                                <children>

                                    <HBox alignment="CENTER_RIGHT">
                                        <children>
                                            <Button text="Export List"
                                                    onAction="#exportAssignments"
                                                    styleClass="btn-secondary"/>
                                        </children>
                                    </HBox>

                                    <TableView fx:id="tableAssignments"
                                               prefHeight="350.0">

                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                        </columnResizePolicy>

                                        <columns>

                                            <TableColumn fx:id="colPerson" text="Person"/>
                                            <TableColumn fx:id="colDepartment" text="Department"/>
                                            <TableColumn fx:id="colEquipment" text="Equipment"/>
                                            <TableColumn fx:id="colReason" text="Reason"/>
                                            <TableColumn fx:id="colQty" text="Qty"/>
                                            <TableColumn fx:id="colStatus" text="Status"/>
                                            <TableColumn fx:id="colDate" text="Date"/>

                                        </columns>

                                    </TableView>

                                </children>
                            </VBox>

                        </content>

                    </TitledPane>

                </VBox>

            </content>

        </ScrollPane>

    </children>

</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="1100.0"
            styleClass="content"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.AssetHistoryController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <VBox spacing="15"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="10"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10">

        <Label text="Asset History" styleClass="header-title"/>

        <HBox spacing="10">
            <TextField fx:id="txtAssetCode" promptText="Enter Asset Code" prefWidth="220"/>
            <Button text="Search" onAction="#handleSearch"/>
            <Button text="Clear" onAction="#handleClear"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Export" onAction="#handleExport"/>
        </HBox>

        <GridPane hgap="18" vgap="10" styleClass="card">
            <columnConstraints>
                <ColumnConstraints percentWidth="16"/>
                <ColumnConstraints percentWidth="17"/>
                <ColumnConstraints percentWidth="16"/>
                <ColumnConstraints percentWidth="17"/>
                <ColumnConstraints percentWidth="16"/>
                <ColumnConstraints percentWidth="18"/>
            </columnConstraints>

            <children>
                <Label text="Asset Code:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblAssetCode" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Serial Number:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <Label fx:id="lblSerialNumber" text="-" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Category:" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
                <Label fx:id="lblCategory" text="-" GridPane.rowIndex="0" GridPane.columnIndex="5"/>

                <Label text="Equipment Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblEquipmentName" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Date Entered:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <Label fx:id="lblEntryDate" text="-" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Current Status:" GridPane.rowIndex="1" GridPane.columnIndex="4"/>
                <Label fx:id="lblCurrentStatus" text="-" GridPane.rowIndex="1" GridPane.columnIndex="5"/>
            </children>
        </GridPane>

        <TableView fx:id="tableHistory" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colActivityDate" text="Activity Date" prefWidth="150"/>
                <TableColumn fx:id="colEventType" text="Event Type" prefWidth="150"/>
                <TableColumn fx:id="colActor" text="Actor" prefWidth="220"/>
                <TableColumn fx:id="colAffectedPerson" text="Affected Person" prefWidth="240"/>
                <TableColumn fx:id="colDetails" text="Details" prefWidth="620"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="150"/>
            </columns>
        </TableView>

    </VBox>

</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="950.0"
            xmlns="http://javafx.com/javafx/11"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.DistributeEquipmentController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>

        <ScrollPane fitToWidth="true" fitToHeight="true"
                    AnchorPane.topAnchor="0"
                    AnchorPane.bottomAnchor="0"
                    AnchorPane.leftAnchor="0"
                    AnchorPane.rightAnchor="0">

            <content>

                <VBox spacing="20" prefWidth="900">
                    <padding>
                        <Insets top="20" left="20" right="20" bottom="20"/>
                    </padding>

                    <!-- TITLE -->
                    <Label text="Distribute Equipment"
                           style="-fx-font-size:20px; -fx-font-weight:bold;" />

                    <!-- ================= ASSIGNMENT ================= -->
                    <TitledPane text="Select Assignment" expanded="true">

                        <content>
                            <VBox spacing="10">
                                <padding>
                                    <Insets top="10" left="10" right="10" bottom="10"/>
                                </padding>

                                <ComboBox fx:id="cmbAssignments" prefWidth="300"/>

                                <Label fx:id="lblSelectedAssignment" text="Selected: -" />
                                <Label fx:id="lblProgress" text="Assigned: 0 / 0" />
                                <Label fx:id="lblAssignmentStats" text="Stats" />

                            </VBox>
                        </content>

                    </TitledPane>

                    <!-- ================= MANUAL ENTRY ================= -->
                    <TitledPane fx:id="manualEntryPane" text="Manual Entry" expanded="true">

                        <content>

                            <GridPane hgap="15" vgap="15">
                                <padding>
                                    <Insets top="10" left="10" right="10" bottom="10"/>
                                </padding>

                                <columnConstraints>
                                    <ColumnConstraints percentWidth="30"/>
                                    <ColumnConstraints percentWidth="70"/>
                                </columnConstraints>

                                <!-- EQUIPMENT (FIXED ROOT ISSUE) -->
                                <Label text="Asset Code:" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="equipmentCombo"
                                          promptText="Select asset code"
                                          prefWidth="300"
                                          GridPane.rowIndex="0"
                                          GridPane.columnIndex="1"/>

                                <!-- NAME -->
                                <Label text="Assigned To:" GridPane.rowIndex="1"/>
                                <TextField fx:id="txtName"
                                           promptText="Enter assigned person"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="1"/>

                                <!-- PHONE -->
                                <Label text="Phone:" GridPane.rowIndex="2"/>
                                <TextField fx:id="txtPhone"
                                           promptText="Enter phone number"
                                           GridPane.rowIndex="2"
                                           GridPane.columnIndex="1"/>

                                <!-- NID -->
                                <Label text="NID:" GridPane.rowIndex="3"/>
                                <TextField fx:id="txtNid"
                                           promptText="Enter national ID"
                                           GridPane.rowIndex="3"
                                           GridPane.columnIndex="1"/>

                                <!-- ADD BUTTON -->
                                <Button text="Add"
                                        fx:id="btnAdd"
                                        onAction="#addManualAssignment"
                                        GridPane.rowIndex="4"
                                        GridPane.columnIndex="1"
                                        style="-fx-background-color:#3498db; -fx-text-fill:white;"/>

                                <!-- SAVE + CLEAR -->
                                <HBox spacing="10"
                                      GridPane.rowIndex="5"
                                      GridPane.columnIndex="1">

                                    <Button text="Save"
                                            fx:id="btnSave"
                                            onAction="#saveEquipment"
                                            style="-fx-background-color:#2ecc71; -fx-text-fill:white;"/>

                                    <Button text="Clear"
                                            fx:id="btnClear"
                                            onAction="#clearForm"
                                            style="-fx-background-color:#95a5a6; -fx-text-fill:white;"/>

                                </HBox>

                            </GridPane>

                        </content>

                    </TitledPane>

                    <!-- ================= BULK IMPORT ================= -->
                    <TitledPane fx:id="bulkImportPane" text="Bulk Import (Excel)" expanded="true">

                        <content>

                            <VBox spacing="10">
                                <padding>
                                    <Insets top="10" left="10" right="10" bottom="10"/>
                                </padding>

                                <Label text="Required columns: asset_code, assigned_to, phone, nid"
                                       style="-fx-text-fill: #4b5563;"/>

                                <Label fx:id="lblSelectedFile"
                                       text="No file selected"
                                       style="-fx-text-fill: gray;"/>

                                <HBox spacing="10">

                                    <Button text="Download Template"
                                            onAction="#downloadTemplate"/>

                                    <Button text="Choose File"
                                            onAction="#chooseExcelFile"/>

                                    <Button text="Upload"
                                            onAction="#uploadExcel"
                                            style="-fx-background-color:#2ecc71; -fx-text-fill:white;"/>

                                </HBox>

                            </VBox>

                        </content>

                    </TitledPane>

                    <!-- ================= TABLE ================= -->
                    <TitledPane text="Distribution List" expanded="true">

                        <content>

                            <TableView fx:id="distributionTable" prefHeight="300">

                                <columns>

                                    <TableColumn fx:id="colDistAsset"
                                                 text="Asset Code"
                                                 prefWidth="150"/>

                                    <TableColumn fx:id="colDistName"
                                                 text="Name"
                                                 prefWidth="150"/>

                                    <TableColumn fx:id="colDistPhone"
                                                 text="Phone"
                                                 prefWidth="150"/>

                                    <TableColumn fx:id="colDistNid"
                                                 text="NID"
                                                 prefWidth="150"/>

                                </columns>

                            </TableView>

                        </content>

                    </TitledPane>

                </VBox>

            </content>

        </ScrollPane>

    </children>

</AnchorPane>

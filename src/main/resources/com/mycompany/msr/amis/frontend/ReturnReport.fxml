<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="1100.0"
            styleClass="content"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.ReturnReportController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <VBox spacing="15"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="10"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10">

        <Label text="Return Report" styleClass="header-title"/>

        <HBox spacing="10">
            <ComboBox fx:id="cmbPerson" promptText="Returned By" prefWidth="180"/>
            <ComboBox fx:id="cmbCondition" promptText="Condition" prefWidth="150"/>
            <DatePicker fx:id="dpFrom" promptText="From" prefWidth="130"/>
            <DatePicker fx:id="dpTo" promptText="To" prefWidth="130"/>
            <Button text="Filter" onAction="#handleFilter"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Export" onAction="#handleExport"/>
            <Button text="PDF" onAction="#handleExportPdf"/>
        </HBox>

        <TableView fx:id="tableReturns" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNo" text="No." minWidth="60" prefWidth="70"/>
                <TableColumn fx:id="colAssetCode" text="Asset Code" minWidth="150" prefWidth="170"/>
                <TableColumn fx:id="colSerialNumber" text="IMEI/Serial Number" minWidth="240" prefWidth="280"/>
                <TableColumn fx:id="colEquipmentName" text="Equipment Name" minWidth="300" prefWidth="340"/>
                <TableColumn fx:id="colCategory" text="Category" minWidth="150" prefWidth="170"/>
                <TableColumn fx:id="colSource" text="Source" minWidth="190" prefWidth="220"/>
                <TableColumn fx:id="colResponsibleOfficer" text="Responsible Officer" minWidth="240" prefWidth="280"/>
                <TableColumn fx:id="colDateTaken" text="Date Given Out" minWidth="160" prefWidth="180"/>
                <TableColumn fx:id="colReason" text="Reason" minWidth="240" prefWidth="280"/>
                <TableColumn fx:id="colReturnedBy" text="Returned By" minWidth="190" prefWidth="220"/>
                <TableColumn fx:id="colPhone" text="Phone" minWidth="130" prefWidth="150"/>
                <TableColumn fx:id="colNID" text="NID" minWidth="140" prefWidth="160"/>
                <TableColumn fx:id="colCondition" text="Return Condition" minWidth="190" prefWidth="220"/>
                <TableColumn fx:id="colRemarks" text="Remarks" minWidth="240" prefWidth="280"/>
                <TableColumn fx:id="colDate" text="Date Returned" minWidth="160" prefWidth="180"/>
            </columns>
        </TableView>

    </VBox>

</AnchorPane>

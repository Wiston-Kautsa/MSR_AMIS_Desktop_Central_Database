<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="1100.0"
            styleClass="content"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.ReturnReportController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <VBox spacing="15"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="10"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10">

        <Label text="Return Report" styleClass="header-title"/>

        <HBox spacing="10">
            <ComboBox fx:id="cmbPerson" promptText="Returned By" prefWidth="180"/>
            <ComboBox fx:id="cmbCondition" promptText="Condition" prefWidth="150"/>
            <Button text="Filter" onAction="#handleFilter"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Export" onAction="#handleExport"/>
        </HBox>

        <TableView fx:id="tableReturns" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colAssetCode" text="Asset Code" prefWidth="110"/>
                <TableColumn fx:id="colSerialNumber" text="IMEI/Serial" prefWidth="120"/>
                <TableColumn fx:id="colEquipmentName" text="Equipment Name" prefWidth="140"/>
                <TableColumn fx:id="colCategory" text="Category" prefWidth="110"/>
                <TableColumn fx:id="colSource" text="Source" prefWidth="120"/>
                <TableColumn fx:id="colResponsibleOfficer" text="Responsible Officer" prefWidth="160"/>
                <TableColumn fx:id="colDateTaken" text="Date Given Out" prefWidth="120"/>
                <TableColumn fx:id="colReason" text="Reason" prefWidth="180"/>
                <TableColumn fx:id="colReturnedBy" text="Returned By" prefWidth="120"/>
                <TableColumn fx:id="colPhone" text="Phone" prefWidth="110"/>
                <TableColumn fx:id="colNID" text="NID" prefWidth="110"/>
                <TableColumn fx:id="colCondition" text="Return Condition" prefWidth="120"/>
                <TableColumn fx:id="colRemarks" text="Remarks" prefWidth="160"/>
                <TableColumn fx:id="colDate" text="Date Returned" prefWidth="110"/>
            </columns>
        </TableView>

    </VBox>

</AnchorPane>

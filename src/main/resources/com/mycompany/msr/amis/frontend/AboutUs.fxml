<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            fitToHeight="true"
            hbarPolicy="NEVER"
            styleClass="dashboard-scroll"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.AboutUsController">

    <content>
        <VBox spacing="25"
              fillWidth="true"
              styleClass="dashboard-content"
              style="-fx-padding:30;">

            <children>

                <HBox alignment="CENTER_LEFT" spacing="14">
                    <children>
                        <Label text="About Us"
                               styleClass="header-title"/>
                    </children>
                </HBox>

                <VBox fx:id="introContainer" spacing="14" styleClass="about-card">
                    <children>
                        <Label text="MSR AMIS"
                               styleClass="about-title"/>
                        <Label fx:id="introParagraphOne"
                               maxWidth="1.7976931348623157E308"
                               styleClass="about-text"
                               wrapText="true"/>
                        <Label fx:id="introParagraphTwo"
                               maxWidth="1.7976931348623157E308"
                               styleClass="about-text"
                               wrapText="true"/>
                    </children>
                </VBox>

                <TitledPane text="System Purpose"
                            expanded="true"
                            collapsible="true"
                            styleClass="dashboard-section">
                    <content>
                        <VBox fx:id="purposeContainer" spacing="12" styleClass="dashboard-section-content">
                            <padding>
                                <Insets top="6" right="6" bottom="6" left="6"/>
                            </padding>
                            <children>
                                <Label fx:id="purposeParagraphOne"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                                <Label fx:id="purposeParagraphTwo"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                                <Label fx:id="purposeParagraphThree"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                            </children>
                        </VBox>
                    </content>
                </TitledPane>

                <TitledPane text="Key Functions"
                            expanded="true"
                            collapsible="true"
                            styleClass="dashboard-section">
                    <content>
                        <VBox fx:id="keyFunctionsContainer" spacing="12" styleClass="dashboard-section-content">
                            <padding>
                                <Insets top="6" right="6" bottom="6" left="6"/>
                            </padding>
                            <children>
                                <Label fx:id="keyFunctionsParagraphOne"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                                <Label fx:id="keyFunctionsParagraphTwo"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                                <Label fx:id="keyFunctionsParagraphThree"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                                <Label fx:id="keyFunctionsParagraphFour"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                                <Label fx:id="keyFunctionsParagraphFive"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                            </children>
                        </VBox>
                    </content>
                </TitledPane>

                <TitledPane text="Why It Matters"
                            expanded="true"
                            collapsible="true"
                            styleClass="dashboard-section">
                    <content>
                        <VBox fx:id="whyItMattersContainer" spacing="12" styleClass="dashboard-section-content">
                            <padding>
                                <Insets top="6" right="6" bottom="6" left="6"/>
                            </padding>
                            <children>
                                <Label fx:id="whyItMattersParagraphOne"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                                <Label fx:id="whyItMattersParagraphTwo"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                                <Label fx:id="whyItMattersParagraphThree"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                                <Label fx:id="whyItMattersParagraphFour"
                                       maxWidth="1.7976931348623157E308"
                                       styleClass="about-text"
                                       wrapText="true"/>
                            </children>
                        </VBox>
                    </content>
                </TitledPane>

                <TitledPane text="Developer"
                            expanded="true"
                            collapsible="true"
                            styleClass="dashboard-section">
                    <content>
                        <HBox spacing="18" styleClass="dashboard-section-content">
                            <padding>
                                <Insets top="6" right="6" bottom="6" left="6"/>
                            </padding>
                            <children>
                                <VBox spacing="10" styleClass="developer-photo-card">
                                    <children>
                                        <ImageView fitWidth="180"
                                                   fitHeight="220"
                                                   pickOnBounds="true"
                                                   preserveRatio="true"
                                                   styleClass="developer-photo">
                                            <image>
                                                <Image url="@wiston-kautsa.png"/>
                                            </image>
                                        </ImageView>
                                        <Label text="Wiston Kautsa"
                                               styleClass="developer-name"/>
                                    </children>
                                </VBox>

                                <VBox fx:id="developerTextContainer" spacing="12" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="developerParagraphOne"
                                               maxWidth="1.7976931348623157E308"
                                               styleClass="about-text"
                                               wrapText="true"/>
                                        <Label fx:id="developerParagraphTwo"
                                               maxWidth="1.7976931348623157E308"
                                               styleClass="about-text"
                                               wrapText="true"/>
                                        <Label fx:id="developerParagraphThree"
                                               maxWidth="1.7976931348623157E308"
                                               styleClass="about-text"
                                               wrapText="true"/>
                                        <Label fx:id="developerParagraphFour"
                                               maxWidth="1.7976931348623157E308"
                                               styleClass="about-text"
                                               wrapText="true"/>
                                        <Label fx:id="developerParagraphFive"
                                               maxWidth="1.7976931348623157E308"
                                               styleClass="about-text"
                                               wrapText="true"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </content>
                </TitledPane>

                <VBox fx:id="summaryContainer" spacing="10" styleClass="about-card">
                    <children>
                        <Label text="Summary"
                               styleClass="about-title"/>
                        <Label fx:id="summaryParagraph"
                               maxWidth="1.7976931348623157E308"
                               styleClass="about-quote"
                               wrapText="true"/>
                    </children>
                </VBox>

            </children>

        </VBox>
    </content>

</ScrollPane>

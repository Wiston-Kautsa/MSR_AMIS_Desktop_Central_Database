<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="760.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.BackupSyncController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>
        <VBox spacing="15.0"
              AnchorPane.topAnchor="15.0"
              AnchorPane.bottomAnchor="15.0"
              AnchorPane.leftAnchor="15.0"
              AnchorPane.rightAnchor="15.0">

            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="page-header">
                <children>
                    <VBox spacing="4.0">
                        <children>
                            <Label text="Backup &amp; Restore" styleClass="page-title"/>
                            <Label text="Manage backup creation, restore, submission, approval, and official version control"
                                   styleClass="page-subtitle"/>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <TitledPane text="System Snapshot" expanded="true" animated="false" styleClass="section-pane">
                <content>
                    <GridPane hgap="15.0" vgap="15.0">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25.0"/>
                            <ColumnConstraints percentWidth="25.0"/>
                            <ColumnConstraints percentWidth="25.0"/>
                            <ColumnConstraints percentWidth="25.0"/>
                        </columnConstraints>

                        <children>
                            <VBox GridPane.columnIndex="0" spacing="8.0" styleClass="summary-card">
                                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                                <children>
                                    <Label text="Current Role" styleClass="card-title"/>
                                    <Label fx:id="lblCurrentRole" text="ADMIN" styleClass="card-value role-pill"/>
                                </children>
                            </VBox>

                            <VBox GridPane.columnIndex="1" spacing="8.0" styleClass="summary-card">
                                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                                <children>
                                    <Label text="Latest Official Version" styleClass="card-title"/>
                                    <Label fx:id="lblLatestOfficialVersion" text="Not Available" styleClass="card-value"/>
                                </children>
                            </VBox>

                            <VBox GridPane.columnIndex="2" spacing="8.0" styleClass="summary-card">
                                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                                <children>
                                    <Label text="My Local Version" styleClass="card-title"/>
                                    <Label fx:id="lblLocalVersion" text="Unknown" styleClass="card-value"/>
                                </children>
                            </VBox>

                            <VBox GridPane.columnIndex="3" spacing="8.0" styleClass="summary-card">
                                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                                <children>
                                    <Label text="Last Backup" styleClass="card-title"/>
                                    <Label fx:id="lblLastBackup" text="No backup yet" styleClass="card-value"/>
                                </children>
                            </VBox>
                        </children>
                    </GridPane>
                </content>
            </TitledPane>

            <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                <children>
                    <VBox spacing="15.0" prefWidth="430.0">
                        <children>
                            <TitledPane text="Operation Progress" expanded="true" animated="false" styleClass="section-pane">
                                <content>
                                    <VBox spacing="10.0" styleClass="content-card">
                                        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                                        <children>
                                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                <children>
                                                    <Label fx:id="lblOperationState"
                                                           text="Idle"
                                                           maxWidth="1.7976931348623157E308"
                                                           HBox.hgrow="ALWAYS"
                                                           styleClass="flow-stage-title"/>
                                                    <Label fx:id="lblOperationPercent" text="0%" styleClass="progress-percent"/>
                                                </children>
                                            </HBox>
                                            <ProgressBar fx:id="progressOperation" progress="0.0" maxWidth="1.7976931348623157E308" styleClass="operation-progress"/>
                                        </children>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Restore Latest Official" expanded="true" animated="false" styleClass="section-pane">
                                <content>
                                    <VBox spacing="12.0" styleClass="content-card">
                                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                        <children>
                                            <Button fx:id="btnRestoreLatestOfficial"
                                                    text="Restore Latest Official"
                                                    onAction="#handleRestoreLatestOfficial"
                                                    prefHeight="40.0"
                                                    maxWidth="1.7976931348623157E308"
                                                    styleClass="action-button"/>
                                        </children>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Submit Backup" expanded="true" animated="false" styleClass="section-pane">
                                <content>
                                    <VBox spacing="12.0" styleClass="content-card">
                                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                        <children>
                                            <Button fx:id="btnSubmitBackup"
                                                    text="Submit Backup"
                                                    onAction="#handleSubmitBackup"
                                                    prefHeight="40.0"
                                                    maxWidth="1.7976931348623157E308"
                                                    styleClass="action-button"/>
                                        </children>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Current Paths" expanded="true" animated="false" styleClass="section-pane">
                                <content>
                                    <VBox spacing="10.0" styleClass="content-card">
                                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                        <children>
                                            <Label text="Official Path" styleClass="input-label"/>
                                            <TextField fx:id="txtOfficialPath" editable="false" styleClass="path-field"/>

                                            <Label text="Submissions Path" styleClass="input-label"/>
                                            <TextField fx:id="txtSubmissionsPath" editable="false" styleClass="path-field"/>

                                            <Label text="Local Backup Path" styleClass="input-label"/>
                                            <TextField fx:id="txtLocalBackupPath" editable="false" styleClass="path-field"/>
                                        </children>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Result" expanded="true" animated="false" styleClass="section-pane">
                                <content>
                                    <VBox fx:id="feedbackPanel" spacing="10.0" styleClass="content-card feedback-panel">
                                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                        <children>
                                            <Label fx:id="lblFeedbackTitle"
                                                   text="Ready"
                                                   styleClass="feedback-title"/>
                                            <Label fx:id="lblFeedbackSummary"
                                                   text=""
                                                   wrapText="true"
                                                   managed="false"
                                                   visible="false"
                                                   styleClass="helper-text"/>
                                            <TextArea fx:id="txtDisplayContent"
                                                      editable="false"
                                                      wrapText="true"
                                                      prefRowCount="4"
                                                      styleClass="feedback-content"/>
                                        </children>
                                    </VBox>
                                </content>
                            </TitledPane>
                        </children>
                    </VBox>

                    <TitledPane fx:id="superAdminPanel"
                                text="Super Admin Controls"
                                expanded="true"
                                animated="false"
                                HBox.hgrow="ALWAYS"
                                styleClass="section-pane">
                        <content>
                            <VBox spacing="15.0" styleClass="content-card">
                                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                                <children>
                                    <TitledPane text="Approval Actions" expanded="true" animated="false" styleClass="section-pane">
                                        <content>
                                            <VBox spacing="12.0" styleClass="content-card">
                                                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                                                <children>
                                                    <HBox spacing="10.0">
                                                        <children>
                                                            <Button fx:id="btnReviewSubmission"
                                                                    text="Review Selected"
                                                                    onAction="#handleReviewSubmission"
                                                                    prefHeight="36.0"
                                                                    styleClass="secondary-button"/>

                                                            <Button fx:id="btnRefreshSubmissions"
                                                                    text="Refresh Submissions"
                                                                    onAction="#handleRefreshSubmissions"
                                                                    prefHeight="36.0"
                                                                    styleClass="secondary-button"/>

                                                            <Button fx:id="btnApprovePublish"
                                                                    text="Approve &amp; Publish"
                                                                    onAction="#handleApproveAndPublish"
                                                                    prefHeight="36.0"
                                                                    styleClass="action-button"/>
                                                        </children>
                                                    </HBox>

                                                    <VBox spacing="6.0" styleClass="process-card">
                                                        <children>
                                                            <Label text="Review before publish." styleClass="input-label"/>
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </VBox>
                                        </content>
                                    </TitledPane>

                                    <TitledPane text="Submission Review" expanded="true" animated="false" styleClass="section-pane">
                                        <content>
                                            <VBox spacing="10.0" styleClass="content-card">
                                                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                                                <children>
                                                    <HBox spacing="12.0">
                                                        <children>
                                                            <VBox spacing="4.0" HBox.hgrow="ALWAYS" styleClass="process-card">
                                                                <children>
                                                                    <Label text="Selected Submission" styleClass="input-label"/>
                                                                    <Label fx:id="lblReviewSubmission" text="Select a submitted backup to review." styleClass="flow-stage-copy" wrapText="true"/>
                                                                </children>
                                                            </VBox>

                                                            <VBox spacing="4.0" HBox.hgrow="ALWAYS" styleClass="process-card">
                                                                <children>
                                                                    <Label text="Compatibility" styleClass="input-label"/>
                                                                    <Label fx:id="lblReviewStatus" text="Not Reviewed" styleClass="flow-stage-title" wrapText="true"/>
                                                                </children>
                                                            </VBox>
                                                        </children>
                                                    </HBox>

                                                    <TextArea fx:id="txtReviewDetails"
                                                              editable="false"
                                                              wrapText="true"
                                                              prefRowCount="10"
                                                              styleClass="feedback-content"/>
                                                </children>
                                            </VBox>
                                        </content>
                                    </TitledPane>

                                    <TitledPane text="Submitted Backups" expanded="true" animated="false" styleClass="section-pane">
                                        <content>
                                            <VBox spacing="10.0" styleClass="content-card">
                                                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                                                <children>
                                                    <TableView fx:id="tblSubmissions" VBox.vgrow="ALWAYS">
                                                        <columns>
                                                            <TableColumn fx:id="colSubmissionFileName" text="File Name" prefWidth="280.0"/>
                                                            <TableColumn fx:id="colSubmissionBy" text="Submitted By" prefWidth="140.0"/>
                                                            <TableColumn fx:id="colSubmissionDate" text="Submitted At" prefWidth="170.0"/>
                                                            <TableColumn fx:id="colSubmissionStatus" text="Status" prefWidth="120.0"/>
                                                        </columns>
                                                    </TableView>
                                                </children>
                                            </VBox>
                                        </content>
                                    </TitledPane>

                                    <TitledPane text="Official Version History" expanded="true" animated="false" styleClass="section-pane">
                                        <content>
                                            <VBox spacing="10.0" styleClass="content-card">
                                                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                                                <children>
                                                    <TableView fx:id="tblOfficialHistory" prefHeight="180.0">
                                                        <columns>
                                                            <TableColumn fx:id="colOfficialFileName" text="Official File" prefWidth="320.0"/>
                                                            <TableColumn fx:id="colOfficialDate" text="Published At" prefWidth="180.0"/>
                                                            <TableColumn fx:id="colOfficialBy" text="Published By" prefWidth="160.0"/>
                                                        </columns>
                                                    </TableView>
                                                </children>
                                            </VBox>
                                        </content>
                                    </TitledPane>

                                </children>
                            </VBox>
                        </content>
                    </TitledPane>
                </children>
            </HBox>

            <TitledPane text="My Backup History" expanded="true" animated="false" styleClass="section-pane">
                <content>
                    <VBox spacing="10.0" styleClass="content-card">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <children>
                            <TableView fx:id="tblMyBackups" prefHeight="170.0">
                                <columns>
                                    <TableColumn fx:id="colMyBackupFileName" text="Backup File" prefWidth="350.0"/>
                                    <TableColumn fx:id="colMyBackupDate" text="Created At" prefWidth="180.0"/>
                                    <TableColumn fx:id="colMyBackupLocation" text="Location" prefWidth="300.0"/>
                                    <TableColumn fx:id="colMyBackupStatus" text="Status" prefWidth="120.0"/>
                                </columns>
                            </TableView>
                        </children>
                    </VBox>
                </content>
            </TitledPane>

            <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="status-bar">
                <children>
                    <Label text="Status:" styleClass="status-label"/>
                    <Label fx:id="lblStatus" text="Ready" styleClass="status-value"/>
                </children>
            </HBox>
        </VBox>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            styleClass="content"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.AssignmentListController">

    <!-- ================= STYLES ================= -->
    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <!-- ================= MAIN CONTAINER ================= -->
    <VBox spacing="15"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="10"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10">

        <!-- ================= HEADER ================= -->
        <HBox spacing="10" alignment="CENTER_LEFT">

            <Label text="Assignment List" styleClass="header-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="txtSearch"
                       promptText="Search assignment..."
                       prefWidth="250"/>

            <Button text="Search" onAction="#searchAssignment"/>

        </HBox>

        <!-- ================= TABLE ================= -->
        <TableView fx:id="tableAssignments"
                   VBox.vgrow="ALWAYS">

            <columns>

                <TableColumn fx:id="colId" text="ID"/>

                <TableColumn fx:id="colPerson" text="Officer"/>

                <TableColumn fx:id="colDepartment" text="Department"/>

                <TableColumn fx:id="colEquipment" text="Equipment"/>

                <TableColumn fx:id="colReason" text="Reason"/>

                <TableColumn fx:id="colQty" text="Qty"/>

                <TableColumn fx:id="colAssigned" text="Assigned"/>

                <TableColumn fx:id="colStatus" text="Status"/>

                <TableColumn fx:id="colDate" text="Date"/>

            </columns>

        </TableView>

    </VBox>

</AnchorPane>

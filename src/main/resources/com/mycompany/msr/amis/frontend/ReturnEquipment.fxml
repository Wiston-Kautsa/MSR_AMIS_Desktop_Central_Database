<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            styleClass="content"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.ReturnEquipmentController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <VBox spacing="15"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="10"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10">

        <!-- TITLE -->
        <Label text="Return Equipment" styleClass="header-title"/>

        <!-- ================= SECTION 1 ================= -->
        <TitledPane text="Assignment Details" expanded="true">

            <VBox spacing="10">

                <HBox spacing="10">
                    <Label text="Select Assignment:"/>
                    <ComboBox fx:id="cmbAssignments" prefWidth="250"/>
                </HBox>

                <GridPane hgap="10" vgap="10">

                    <Label text="Officer:" GridPane.rowIndex="0"/>
                    <Label fx:id="lblAssignOfficer" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Equipment Type:" GridPane.rowIndex="1"/>
                    <Label fx:id="lblAssignType" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Total Assigned:" GridPane.rowIndex="2"/>
                    <Label fx:id="lblAssignQty" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                </GridPane>

            </VBox>

        </TitledPane>

        <!-- ================= SECTION 2 ================= -->
        <TitledPane text="Return Entry" expanded="true">

            <GridPane hgap="30" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox fx:id="outstandingReasonPane"
                      spacing="8"
                      visible="false"
                      managed="false"
                      GridPane.columnIndex="0"
                      GridPane.columnSpan="2"
                      GridPane.rowIndex="0"
                      fillWidth="true">
                    <Label text="Outstanding Equipment Reason" styleClass="card-title"/>
                    <Label text="These assigned equipment items are not included in this return. Enter one reason explaining why they are not being returned now."
                           wrapText="true"/>
                    <TableView fx:id="tableOutstandingAssets"
                               prefHeight="125"
                               maxWidth="1.7976931348623157E308">
                        <columns>
                            <TableColumn fx:id="colOutstandingNo" text="No." prefWidth="55"/>
                            <TableColumn fx:id="colOutstandingAsset" text="Asset" prefWidth="160"/>
                            <TableColumn fx:id="colOutstandingUser" text="Assigned To" prefWidth="220"/>
                            <TableColumn fx:id="colOutstandingPhone" text="Phone" prefWidth="150"/>
                            <TableColumn fx:id="colOutstandingNid" text="NID" prefWidth="180"/>
                        </columns>
                    </TableView>
                    <TextArea fx:id="txtOutstandingReason"
                              promptText="Example: Still with field team and will be returned after supervision closes."
                              wrapText="true"
                              prefRowCount="3"
                              maxWidth="1.7976931348623157E308"/>
                    <Button fx:id="btnApplyOutstandingReason"
                            text="Enter Reason"
                            maxWidth="180"
                            onAction="#enterOutstandingReason"/>
                </VBox>

                <!-- LEFT: MANUAL -->
                <VBox fx:id="manualEntryPane" spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="1" fillWidth="true">

                    <Label text="Manual Entry" styleClass="card-title"/>

                    <Label fx:id="lblReturnProgress" text="Entered Returns: 0 / 0"/>
                    <Label text="New IMEI/serial: registers replacement and returns the old asset."
                           wrapText="true"/>

                    <GridPane hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="45"/>
                            <ColumnConstraints percentWidth="55"/>
                        </columnConstraints>

                        <Label text="Asset Code / New IMEI:" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtAssetCode" onAction="#handleReturn" maxWidth="1.7976931348623157E308" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Responsible Officer:" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtOfficer" onAction="#handleReturn" maxWidth="1.7976931348623157E308" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Equipment Type:" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtEquipmentType" onAction="#handleReturn" maxWidth="1.7976931348623157E308" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Returned By:" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtReturnedBy" onAction="#handleReturn" maxWidth="1.7976931348623157E308" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Phone:" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtPhone" onAction="#handleReturn" maxWidth="1.7976931348623157E308" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <Label text="NID:" GridPane.rowIndex="5"/>
                        <TextField fx:id="txtNid" onAction="#handleReturn" maxWidth="1.7976931348623157E308" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                        <Label text="Condition:" GridPane.rowIndex="6"/>
                        <ComboBox fx:id="cmbCondition" maxWidth="1.7976931348623157E308" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                        <Label text="Remarks:" GridPane.rowIndex="7"/>
                        <TextField fx:id="txtRemarks" onAction="#handleReturn" maxWidth="1.7976931348623157E308" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                    </GridPane>

                    <HBox spacing="10">
                        <Button fx:id="btnAddReturn" text="Add Return" defaultButton="true" onAction="#handleReturn"/>
                        <Button fx:id="btnSaveReturns" text="Save" defaultButton="true" onAction="#saveReturns"/>
                        <Button fx:id="btnClear" text="Clear" onAction="#clearForm"/>
                    </HBox>

                </VBox>

            </GridPane>

        </TitledPane>

        <!-- ================= SECTION 3 ================= -->
        <TitledPane text="Bulk Import (Excel)" expanded="true">

            <VBox fx:id="bulkImportPane" spacing="14">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <Label text="Required columns: asset_code_or_imei, returned_by, phone, nid, return_condition, remarks"
                       style="-fx-text-fill: #4b5563;"/>

                <Label fx:id="lblFileName"
                       text="No file selected"
                       style="-fx-text-fill: gray;"
                       wrapText="true"/>

                <HBox spacing="10">
                    <Button fx:id="btnDownloadTemplate"
                            text="Download Template"
                            onAction="#downloadTemplate"/>
                    <Button fx:id="btnChooseFile"
                            text="Choose File"
                            onAction="#chooseFile"/>
                    <Button fx:id="btnUpload"
                            text="Upload"
                            onAction="#handleBulkUpload"
                            style="-fx-background-color:#2ecc71; -fx-text-fill:white;"/>
                </HBox>

                <VBox spacing="6">
                    <ProgressBar fx:id="progressBulkUpload"
                                 maxWidth="Infinity"
                                 prefHeight="16"
                                 progress="0"/>
                    <Label fx:id="lblBulkUploadProgress"
                           text="No upload running"
                           style="-fx-text-fill: #4b5563;"/>
                </VBox>
            </VBox>

        </TitledPane>

        <!-- ================= SECTION 4 ================= -->
        <TitledPane text="Returned Equipment" expanded="true">

            <TableView fx:id="tableReturns">

                <columns>

                    <TableColumn fx:id="colReturnNo" text="No." prefWidth="55"/>
                    <TableColumn fx:id="colAsset" text="Asset Code"/>
                    <TableColumn fx:id="colReturnedBy" text="Returned By"/>
                    <TableColumn fx:id="colPhone" text="Phone"/>
                    <TableColumn fx:id="colNid" text="NID"/>
                    <TableColumn fx:id="colCondition" text="Condition"/>
                    <TableColumn fx:id="colDate" text="Date"/>

                </columns>

            </TableView>

        </TitledPane>

    </VBox>

</AnchorPane>

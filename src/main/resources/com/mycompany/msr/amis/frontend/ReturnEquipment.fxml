<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            styleClass="content"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.ReturnEquipmentController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <VBox spacing="15"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="10"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10">

        <!-- TITLE -->
        <Label text="Return Equipment" styleClass="header-title"/>

        <!-- ================= SECTION 1 ================= -->
        <TitledPane text="Assignment Details" expanded="true">

            <VBox spacing="10">

                <HBox spacing="10">
                    <Label text="Select Assignment:"/>
                    <ComboBox fx:id="cmbAssignments" prefWidth="250"/>
                </HBox>

                <GridPane hgap="10" vgap="10">

                    <Label text="Officer:" GridPane.rowIndex="0"/>
                    <Label fx:id="lblAssignOfficer" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Equipment Type:" GridPane.rowIndex="1"/>
                    <Label fx:id="lblAssignType" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Total Assigned:" GridPane.rowIndex="2"/>
                    <Label fx:id="lblAssignQty" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                </GridPane>

            </VBox>

        </TitledPane>

        <!-- ================= SECTION 2 ================= -->
        <TitledPane text="Return Entry" expanded="true">

            <GridPane hgap="30" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <!-- LEFT: MANUAL -->
                <VBox spacing="10" GridPane.columnIndex="0" fillWidth="true">

                    <Label text="Manual Entry" styleClass="card-title"/>

                    <Label fx:id="lblReturnProgress" text="Entered Returns: 0 / 0"/>
                    <Label text="New IMEI/serial: registers replacement and returns the old asset."
                           wrapText="true"/>

                    <GridPane hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="45"/>
                            <ColumnConstraints percentWidth="55"/>
                        </columnConstraints>

                        <Label text="Asset Code / New IMEI:" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtAssetCode" maxWidth="1.7976931348623157E308" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Responsible Officer:" GridPane.rowIndex="1"/>
                        <TextField fx:id="txtOfficer" maxWidth="1.7976931348623157E308" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Equipment Type:" GridPane.rowIndex="2"/>
                        <TextField fx:id="txtEquipmentType" maxWidth="1.7976931348623157E308" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Returned By:" GridPane.rowIndex="3"/>
                        <TextField fx:id="txtReturnedBy" maxWidth="1.7976931348623157E308" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Phone:" GridPane.rowIndex="4"/>
                        <TextField fx:id="txtPhone" maxWidth="1.7976931348623157E308" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <Label text="NID:" GridPane.rowIndex="5"/>
                        <TextField fx:id="txtNid" maxWidth="1.7976931348623157E308" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                        <Label text="Condition:" GridPane.rowIndex="6"/>
                        <ComboBox fx:id="cmbCondition" maxWidth="1.7976931348623157E308" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                        <Label text="Remarks:" GridPane.rowIndex="7"/>
                        <TextField fx:id="txtRemarks" maxWidth="1.7976931348623157E308" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Add Return" onAction="#handleReturn"/>
                        <Button fx:id="btnSaveReturns" text="Save" onAction="#saveReturns"/>
                        <Button text="Clear" onAction="#clearForm"/>
                    </HBox>

                </VBox>

                <!-- RIGHT: BULK -->
                <VBox spacing="14" GridPane.columnIndex="1" fillWidth="true">

                    <Label text="Bulk Upload" styleClass="card-title"/>
                    <Label text="Upload many returns at once. Use the template so the system reads the file correctly."
                           wrapText="true"/>

                    <VBox spacing="10">
                        <Button text="Download Template"
                                maxWidth="1.7976931348623157E308"
                                onAction="#downloadTemplate"/>
                        <Button text="Choose File"
                                maxWidth="1.7976931348623157E308"
                                onAction="#chooseFile"/>
                        <Label fx:id="lblFileName"
                               text="No file selected"
                               wrapText="true"/>
                        <Button text="Upload"
                                maxWidth="1.7976931348623157E308"
                                onAction="#handleBulkUpload"/>
                        <Region VBox.vgrow="ALWAYS"/>
                    </VBox>

                </VBox>

            </GridPane>

        </TitledPane>

        <!-- ================= SECTION 3 ================= -->
        <TitledPane text="Returned Equipment" expanded="true">

            <TableView fx:id="tableReturns">

                <columns>

                    <TableColumn fx:id="colAsset" text="Asset Code"/>
                    <TableColumn fx:id="colReturnedBy" text="Returned By"/>
                    <TableColumn fx:id="colPhone" text="Phone"/>
                    <TableColumn fx:id="colCondition" text="Condition"/>
                    <TableColumn fx:id="colDate" text="Date"/>

                </columns>

            </TableView>

        </TitledPane>

    </VBox>

</AnchorPane>

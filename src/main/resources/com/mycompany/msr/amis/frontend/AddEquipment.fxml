<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="980.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.AddEquipmentController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    styleClass="dashboard-scroll"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <content>
                <VBox spacing="18.0" styleClass="page-shell">
                    <padding>
                        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
                    </padding>

                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Add Equipment" styleClass="page-title"/>
                                <Label text="Register new assets manually or import them in bulk from Excel"
                                       styleClass="page-subtitle"/>
                            </children>
                        </VBox>

                        <TitledPane text="Manual Equipment Entry" expanded="true" animated="false" styleClass="section-pane">
                            <content>
                                <VBox spacing="18.0" styleClass="content-card">
                                    <padding>
                                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                                    </padding>

                                    <children>
                                        <GridPane hgap="16.0" vgap="14.0" styleClass="form-grid">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="18.0"/>
                                                <ColumnConstraints percentWidth="32.0"/>
                                                <ColumnConstraints percentWidth="18.0"/>
                                                <ColumnConstraints percentWidth="32.0"/>
                                            </columnConstraints>

                                            <children>
                                                <Label text="Equipment Name" styleClass="input-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                                <TextField fx:id="txtName"
                                                           promptText="Example: Tablet"
                                                           GridPane.rowIndex="0"
                                                           GridPane.columnIndex="1"/>

                                                <Label text="Category" styleClass="input-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                                <ComboBox fx:id="cmbCategory"
                                                          prefWidth="240.0"
                                                          GridPane.rowIndex="0"
                                                          GridPane.columnIndex="3"/>

                                                <Label text="IMEI / Serial Number" styleClass="input-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                                <TextField fx:id="txtSerialNumber"
                                                           promptText="Enter manufacturer serial number"
                                                           GridPane.rowIndex="1"
                                                           GridPane.columnIndex="1"/>

                                                <Label text="Source" styleClass="input-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                                                <TextField fx:id="txtSource"
                                                           promptText="Example: World Bank"
                                                           GridPane.rowIndex="1"
                                                           GridPane.columnIndex="3"/>

                                                <Label text="Condition" styleClass="input-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                                <ComboBox fx:id="cmbCondition"
                                                          prefWidth="220.0"
                                                          GridPane.rowIndex="2"
                                                          GridPane.columnIndex="1"/>

                                                <Label text="Entry Date" styleClass="input-label" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                                                <DatePicker fx:id="dateEntry"
                                                            GridPane.rowIndex="2"
                                                            GridPane.columnIndex="3"/>
                                            </children>
                                        </GridPane>

                                        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="toolbar-row">
                                            <children>
                                                <Button text="Clear"
                                                        onAction="#clearForm"
                                                        styleClass="secondary-button"/>
                                                <Button text="Save Equipment"
                                                        onAction="#saveEquipment"
                                                        styleClass="action-button"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>

                        <TitledPane text="Bulk Equipment Import" expanded="true" animated="false" styleClass="section-pane">
                            <content>
                                <VBox spacing="16.0" styleClass="content-card">
                                    <padding>
                                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                                    </padding>

                                    <children>
                                        <Label text="Download the Excel template, fill in the equipment details, then upload the file to import records."
                                               wrapText="true"
                                               styleClass="helper-text"/>

                                        <Label fx:id="lblSelectedFile"
                                               text="No file selected"
                                               styleClass="status-value"/>

                                        <HBox spacing="12.0" styleClass="toolbar-row">
                                            <children>
                                                <Button text="Download Template"
                                                        onAction="#downloadTemplate"
                                                        styleClass="secondary-button"/>
                                                <Button text="Choose Excel File"
                                                        onAction="#chooseExcelFile"
                                                        styleClass="secondary-button"/>
                                                <Button text="Upload"
                                                        onAction="#uploadExcel"
                                                        styleClass="action-button"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>

                        <TitledPane text="Equipment Inventory" expanded="true" animated="false" styleClass="section-pane">
                            <content>
                                <VBox spacing="10.0" styleClass="content-card">
                                    <padding>
                                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                                    </padding>

                                    <children>
                                        <TableView fx:id="equipmentTable" prefHeight="320.0">
                                            <columns>
                                                <TableColumn fx:id="colName" text="Name" prefWidth="170.0"/>
                                                <TableColumn fx:id="colCategory" text="Category" prefWidth="140.0"/>
                                                <TableColumn fx:id="colSerial" text="IMEI / Serial Number" prefWidth="220.0"/>
                                                <TableColumn fx:id="colCondition" text="Condition" prefWidth="140.0"/>
                                                <TableColumn fx:id="colDate" text="Entry Date" prefWidth="150.0"/>
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>

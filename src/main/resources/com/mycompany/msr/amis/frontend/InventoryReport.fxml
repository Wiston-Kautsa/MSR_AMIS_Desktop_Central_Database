<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            styleClass="content"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.InventoryReportController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <VBox spacing="15"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="10"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10">

        <!-- ================= TITLE ================= -->
        <Label text="Inventory Report" styleClass="header-title"/>

        <!-- ================= FILTERS ================= -->
        <HBox spacing="10">

            <ComboBox fx:id="cmbCategory"
                      promptText="Select Category"
                      prefWidth="180"/>

            <ComboBox fx:id="cmbStatus"
                      promptText="Select Status"
                      prefWidth="180"/>

            <DatePicker fx:id="dpFrom"
                        promptText="From"
                        prefWidth="130"/>

            <DatePicker fx:id="dpTo"
                        promptText="To"
                        prefWidth="130"/>

            <Button text="Filter"
                    onAction="#handleFilter"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- EXPORT BUTTON -->
            <Button text="Export"
                    onAction="#handleExport"/>

            <Button text="PDF"
                    onAction="#handleExportPdf"/>

        </HBox>

        <!-- ================= TABLE ================= -->
        <TableView fx:id="tableInventory"
                   VBox.vgrow="ALWAYS">

            <columns>

                <TableColumn fx:id="colNo" text="No." prefWidth="55"/>

                <TableColumn fx:id="colAssetCode" text="Asset Code" prefWidth="130"/>

                <TableColumn fx:id="colName" text="Name" prefWidth="160"/>

                <TableColumn fx:id="colCategory" text="Category" prefWidth="130"/>

                <TableColumn fx:id="colSerial" text="IMEI/Serial Number" prefWidth="180"/>

                <TableColumn fx:id="colCondition" text="Condition" prefWidth="130"/>

                <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>

                 <TableColumn fx:id="colSource" text="Source" prefWidth="130"/>

                 <TableColumn fx:id="colPurchaseCost" text="Purchase Cost" prefWidth="150"/>

                 <TableColumn fx:id="colLocation" text="Location" prefWidth="140"/>

                 <TableColumn fx:id="colWarrantyExpiry" text="Warranty Expiry" prefWidth="160"/>

                 <TableColumn fx:id="colSupplier" text="Supplier" prefWidth="140"/>

                 <TableColumn fx:id="colDate" text="Entry Date" prefWidth="130"/>

            </columns>

        </TableView>

    </VBox>

</AnchorPane>

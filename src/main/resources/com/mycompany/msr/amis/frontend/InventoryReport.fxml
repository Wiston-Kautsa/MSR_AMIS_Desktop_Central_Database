<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            styleClass="content"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.InventoryReportController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <VBox spacing="15"
          AnchorPane.topAnchor="10"
          AnchorPane.bottomAnchor="10"
          AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10">

        <!-- ================= TITLE ================= -->
        <Label text="Inventory Report" styleClass="header-title"/>

        <!-- ================= FILTERS ================= -->
        <HBox spacing="10">

            <ComboBox fx:id="cmbCategory"
                      promptText="Select Category"
                      prefWidth="180"/>

            <ComboBox fx:id="cmbStatus"
                      promptText="Select Status"
                      prefWidth="180"/>

            <Button text="Filter"
                    onAction="#handleFilter"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- EXPORT BUTTON -->
            <Button text="Export"
                    onAction="#handleExport"/>

        </HBox>

        <!-- ================= TABLE ================= -->
        <TableView fx:id="tableInventory"
                   VBox.vgrow="ALWAYS">

            <columns>

                <TableColumn fx:id="colAssetCode" text="Asset Code"/>

                <TableColumn fx:id="colName" text="Name"/>

                <TableColumn fx:id="colCategory" text="Category"/>

                <TableColumn fx:id="colSerial" text="IMEI/Serial Number"/>

                <TableColumn fx:id="colCondition" text="Condition"/>

                <TableColumn fx:id="colStatus" text="Status"/>

                <TableColumn fx:id="colSource" text="Source"/>

                <TableColumn fx:id="colDate" text="Entry Date"/>

            </columns>

        </TableView>

    </VBox>

</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="760.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.msr.amis.DepartmentsController">

    <stylesheets>
        <URL value="@theme.css"/>
    </stylesheets>

    <children>
        <VBox spacing="18.0"
              AnchorPane.topAnchor="15.0"
              AnchorPane.bottomAnchor="15.0"
              AnchorPane.leftAnchor="15.0"
              AnchorPane.rightAnchor="15.0">

            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="page-header">
                <children>
                    <VBox spacing="4.0">
                        <children>
                            <Label text="Departments" styleClass="page-title"/>
                            <Label text="Manage department names used by user accounts and assignments"
                                   styleClass="page-subtitle"/>
                        </children>
                    </VBox>
                    <Button fx:id="btnRefreshDepartments"
                            text="Refresh"
                            onAction="#handleRefreshDepartments"
                            styleClass="secondary-button"/>
                </children>
            </HBox>

            <TitledPane text="Department Entry" expanded="true" animated="false" styleClass="section-pane">
                <content>
                    <VBox spacing="12.0" styleClass="content-card">
                        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                        <children>
                            <Label text="Department Name" styleClass="input-label"/>
                            <HBox spacing="10.0">
                                <children>
                                    <TextField fx:id="txtDepartmentName"
                                               promptText="Example: MSR"
                                               onAction="#handleSaveDepartment"
                                               HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btnSaveDepartment"
                                            text="Add Department"
                                            onAction="#handleSaveDepartment"
                                            styleClass="action-button"/>
                                    <Button fx:id="btnClearDepartment"
                                            text="Clear"
                                            onAction="#handleClearDepartment"
                                            styleClass="secondary-button"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </content>
            </TitledPane>

            <TitledPane text="Department List" expanded="true" animated="false" styleClass="section-pane" VBox.vgrow="ALWAYS">
                <content>
                    <VBox spacing="10.0" styleClass="content-card">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <children>
                            <TableView fx:id="tableDepartments" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colDepartmentName" text="Department" prefWidth="420.0"/>
                                </columns>
                            </TableView>
                        </children>
                    </VBox>
                </content>
            </TitledPane>

            <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="status-bar">
                <children>
                    <Label text="Status:" styleClass="status-label"/>
                    <Label fx:id="lblDepartmentStatus" text="Ready" styleClass="status-value" wrapText="true"/>
                </children>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
